// Fadex25/tsconfig.json
{
    "compilerOptions": {
      "target": "ES2020",
      "module": "commonjs",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "outDir": "./dist",
      "rootDir": "./"
    },
    "include": ["server.ts", "api/**/*", "db/**/*"],
    "exclude": ["node_modules", "fadex25-ui", "**/*.bak"]
  }